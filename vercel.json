{
    "cleanUrls": true,
    "redirects": [
        {
            "source": "/upload",
            "destination": "/admin/upload",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/article/styles.css",
            "destination": "/styles.css"
        },
        {
            "source": "/article/script.js",
            "destination": "/script.js"
        },
        {
            "source": "/article/logo.png",
            "destination": "/logo.png"
        },
        {
            "source": "/article/:slug",
            "destination": "/article"
        },
        {
            "source": "/admin/upload",
            "destination": "/upload"
        }
    ]
}