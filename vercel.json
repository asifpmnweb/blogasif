{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/upload(.html)?",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/update_unlist.js",
      "destination": "/404",
      "permanent": true
    },
    {
      "source": "/refactor.js",
      "destination": "/404",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/article/:path*",
      "destination": "/article.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}